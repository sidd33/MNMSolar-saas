generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id              String           @id @default(cuid())
  name            String
  auditLogs       AuditLog[]
  handoffLogs     HandoffLog[]
  leads           Lead[]
  projects        Project[]
  projectFiles    ProjectFile[]
  quotes          Quote[]
  tasks           Task[]
  users           User[]
  notifications   Notification[]
  followUps       FollowUp[]
  quoteVersions   QuoteVersion[]
  projectComments ProjectComment[]
  laborLogs       LaborLog[]
  inventoryItems  InventoryItem[]
  purchaseOrders  PurchaseOrder[]
  mrns            MaterialReleaseNote[]
  challans        Challan[]
}

model User {
  id                 String           @id
  email              String           @unique
  name               String?
  role               String?
  isSuperAdmin       Boolean          @default(false)
  department         String?
  organizationId     String
  auditLogs          AuditLog[]
  handoffLogs        HandoffLog[]
  assignedLeads      Lead[]
  assignedQuotes     Quote[]
  tasks              Task[]           @relation("AssignedTasks")
  claimedProjects    Project[]        @relation("ProjectClaims")
  projectAssignments Project[]        @relation("ProjectAssignments")
  assignedProjects   Project[]        @relation("ProjectAssignedEngineers")
  notifications      Notification[]
  followUps          FollowUp[]
  quoteVersions      QuoteVersion[]
  organization       Organization     @relation(fields: [organizationId], references: [id])
  projectComments    ProjectComment[]
  laborLogs          LaborLog[]

  @@index([organizationId])
}

model Project {
  id                   String           @id @default(cuid())
  name                 String
  stage                PipelineStage    @default(SITE_SURVEY)
  liasoningStage       LiasoningStage   @default(NOT_STARTED)
  executionStage       ExecutionStage   @default(SURVEY)
  isBottlenecked       Boolean          @default(false)
  isPreliminary        Boolean          @default(false)
  currentDepartment    String?
  organizationId       String
  clientName           String?
  address              String?
  dcCapacity           String?          @default("50 kWp")
  sanctionedLoad       String?          @default("40 kW")
  orderValue           String?
  projectType          String?
  primaryContactName   String?
  primaryContactMobile String?
  createdByUserId      String?
  updatedAt            DateTime         @updatedAt
  createdAt            DateTime         @default(now())
  executionMetadata    Json?
  leadId               String?
  originatedByUserId   String?
  handoffLogs          HandoffLog[]
  lead                 Lead?            @relation(fields: [leadId], references: [id])
  organization         Organization     @relation(fields: [organizationId], references: [id])
  projectFiles         ProjectFile[]
  tasks                Task[]
  claimedByUserId      String?
  claimedAt            DateTime?
  poolClaimNote        String?
  poolReleaseNote      String?
  poolNoteAt           DateTime?
  assignedToEngineerId String?
  assignedByUserId     String?
  assignedAt           DateTime?
  claimedBy            User?            @relation("ProjectClaims", fields: [claimedByUserId], references: [id])
  assignedBy           User?            @relation("ProjectAssignments", fields: [assignedByUserId], references: [id])
  assignedEngineers    User[]           @relation("ProjectAssignedEngineers")
  comments             ProjectComment[]
  laborLogs            LaborLog[]
  purchaseOrders       PurchaseOrder[]
  mrns                 MaterialReleaseNote[]
  challans             Challan[]

  @@index([organizationId])
  @@index([currentDepartment])
  @@index([stage])
  @@index([isBottlenecked])
  @@index([updatedAt(sort: Desc)])
}

model ProjectFile {
  id              String       @id @default(cuid())
  name            String
  category        FileCategory
  content         String
  fileUrl         String?
  utFileKey       String?
  isArchived      Boolean      @default(false)
  projectId       String
  organizationId  String
  uploadedAtStage String       @default("UNKNOWN")
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id])
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([organizationId])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         String       @default("TODO")
  priority       String       @default("MEDIUM")
  department     String?
  dueDate        DateTime?
  assigneeId     String?
  projectId      String?
  organizationId String
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())
  auditLogs      AuditLog[]
  assignee       User?        @relation("AssignedTasks", fields: [assigneeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([assigneeId])
  @@index([organizationId])
}

model AuditLog {
  id             String       @id @default(cuid())
  action         String
  oldValue       String?
  newValue       String?
  userId         String
  taskId         String?
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  task           Task?        @relation(fields: [taskId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@index([organizationId])
}

model HandoffLog {
  id             String       @id @default(cuid())
  projectId      String
  fromDept       String
  toDept         String
  fromStage      String
  toStage        String
  userId         String
  comment        String?
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([organizationId])
  @@index([createdAt(sort: Desc)])
}

model StageConfig {
  id           String   @id @default(cuid())
  stage        String   @unique
  expectedDays Int
  label        String
  updatedAt    DateTime @updatedAt
}

model Lead {
  id             String       @id @default(cuid())
  name           String
  contactPerson  String?
  mobile         String?
  email          String?
  siteAddress    String?
  capacityKw     Float?
  estimatedValue Float?
  status         LeadStatus   @default(NEW)
  notes          String?
  assignedToId   String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  projects       Project[]
  quotes         Quote[]
  followUps      FollowUp[]
  lostReason     String?
  lostAt         DateTime?
  lostNote       String?      @db.Text

  @@index([assignedToId])
  @@index([organizationId])
  @@index([updatedAt(sort: Desc)])
}

model Quote {
  id                   String         @id @default(cuid())
  leadId               String?
  projectName          String
  clientName           String
  capacityKw           Float?
  quotedValue          Float?
  status               QuoteStatus    @default(DRAFT)
  notes                String?
  assignedToId         String?
  organizationId       String
  fileUrl              String?
  utFileKey            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  paymentTermsAdvance  Int?
  paymentTermsFinal    Int?
  paymentTermsMaterial Int?
  scopeOfWork          String?
  assignedTo           User?          @relation(fields: [assignedToId], references: [id])
  lead                 Lead?          @relation(fields: [leadId], references: [id])
  organization         Organization   @relation(fields: [organizationId], references: [id])
  versions             QuoteVersion[]

  @@index([leadId])
  @@index([assignedToId])
  @@index([organizationId])
  @@index([updatedAt(sort: Desc)])
}

enum PipelineStage {
  PROSPECT
  PRELIMINARY_QUOTE
  SITE_SURVEY
  DETAILED_ENGG
  WORK_ORDER
  HANDOVER_TO_EXECUTION
  MATERIAL_PROCUREMENT
  STRUCTURE_ERECTION
  PV_PANEL_INSTALLATION
  AC_DC_INSTALLATION
  NET_METERING
  FINAL_HANDOVER
}

enum LiasoningStage {
  NOT_STARTED
  FEASIBILITY
  L1_APPROVED
  AGREEMENT
  COMMISSIONED
}

enum ExecutionStage {
  SURVEY
  STRUCTURE
  PANEL_INSTALL
  INVERTER_WIRING
}

enum FileCategory {
  LIAISONING
  TECHNICAL
  COMMERCIAL
  HANDOVER_SHEET
  EXECUTION
}

enum ChallanStatus {
  RECEIVED
  DISCREPANCY
  CLEARED
}

model LaborLog {
  id             String   @id @default(cuid())
  projectId      String
  date           DateTime @db.Date
  laborCount     Int
  notes          String?
  loggedByUserId String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  loggedBy     User         @relation(fields: [loggedByUserId], references: [id])

  @@unique([projectId, date])
  @@index([projectId])
  @@index([organizationId])
  @@index([date])
}

enum LeadStatus {
  NEW
  CONTACTED
  SITE_VISIT_SCHEDULED
  QUOTE_SENT
  NEGOTIATING
  CONVERTED
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  NEGOTIATING
  APPROVED
  REJECTED
  CONVERTED
}

model Notification {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String
  title          String
  message        String
  projectId      String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([isRead])
}

model FollowUp {
  id             String       @id @default(cuid())
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           String
  note           String       @db.Text
  followUpDate   DateTime?
  isCompleted    Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([organizationId])
}

model QuoteVersion {
  id             String       @id @default(cuid())
  quoteId        String
  quote          Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  versionNumber  Int
  quotedValue    Float?
  fileUrl        String?
  utFileKey      String?
  fileName       String?
  note           String?
  uploadedById   String
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([quoteId])
  @@index([organizationId])
}

model ProjectComment {
  id               String       @id @default(cuid())
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  content          String       @db.Text
  mentionedUserIds Json?
  isHandoff        Boolean      @default(false)
  handoffToUserId  String?
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime     @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([organizationId])
}

model InventoryItem {
  id              String           @id @default(cuid())
  organizationId  String
  sku             String?
  name            String
  category        ItemCategory
  trackingType    ItemTrackingType
  quantityInStock Float            @default(0)
  unit            String           @default("nos")

  transactions InventoryTransaction[]
  organization Organization           @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([category])
}

model InventoryTransaction {
  id          String          @id @default(cuid())
  itemId      String
  quantity    Float
  type        TransactionType
  referenceId String?
  notes       String?
  createdAt   DateTime        @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

enum ItemTrackingType {
  EXACT_COUNT
  VARIABLE_BULK
}

enum ItemCategory {
  MODULES
  INVERTERS
  STRUCTURES
  ELECTRICAL_BOS
  CIVIL_BOS
  GENERAL_CONSUMABLES
}

enum TransactionType {
  IN
  OUT
}

model PurchaseOrder {
  id             String       @id @default(cuid())
  projectId      String
  vendorName     String
  orderType      String
  amount         Float
  items          Json?
  status         String       @default("PENDING")
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project        Project      @relation(fields: [projectId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([projectId])
  @@index([organizationId])
}

model MaterialReleaseNote {
  id             String       @id @default(cuid())
  projectId      String
  mrnNumber      String
  items          Json?
  vehicleNumber  String?
  driverName     String?
  dispatchedBy   String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project        Project      @relation(fields: [projectId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([projectId])
  @@index([organizationId])
}

model Challan {
  id             String       @id @default(cuid())
  projectId      String
  challanNumber  String
  type           String       // 'INWARD' | 'RETURN'
  items          Json?
  loggedByUserId String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project        Project      @relation(fields: [projectId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([projectId])
  @@index([organizationId])
}
